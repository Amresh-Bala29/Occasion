{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://occasion.dev/schemas/event.schema.json",
  "title": "Event",
  "type": "object",
  "required": ["id", "name"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "date": { "type": "string", "format": "date-time" },
    "budget": { "type": "number" },
    "location": { "type": "string" }
  }
}
