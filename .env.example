# ---------------------------------------------------------------------------
# Occasion — environment variable template
# Copy to `.env` and fill in real values. Never commit `.env`.
# ---------------------------------------------------------------------------

# --- General ---------------------------------------------------------------
NODE_ENV=development

# --- Web app (apps/web) ----------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_AGENT_URL=http://localhost:8000

# --- Agent service (services/agent) ----------------------------------------
AGENT_PORT=8000

# --- Database --------------------------------------------------------------
# Supabase Postgres. Use the session pooler (or the direct connection) for the
# long-lived agent service — NOT the transaction pooler (port 6543), whose
# per-statement multiplexing breaks server-side prepared statements. The bare
# postgresql:// scheme is normalized to postgresql+psycopg:// at runtime.
DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres

# --- Supabase --------------------------------------------------------------
# Project URL and API keys from the Supabase dashboard (Settings → API).
# Publishable key is browser-safe; the secret key is server-only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# --- H Company (computer use) ----------------------------------------------
HAI_API_KEY=
HAI_BASE_URL=https://api.hcompany.ai/v1/
# Browser H drives: a cloud Chrome that opens Google and reuses a signed-in profile.
HAI_BROWSER_HOST=cloud
HAI_BROWSER_START_URL=https://www.google.com
HAI_BROWSER_HEADLESS=false
HAI_BROWSER_PERSIST_LOGIN=true

# --- Gradium (voice: speech-to-text / text-to-speech) ----------------------
GRADIUM_API_KEY=

# --- NemoClaw (browser runtime) --------------------------------------------
NEMOCLAW_CONFIG=infra/nemoclaw/config.yaml
