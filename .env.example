# ---------------------------------------------------------------------------
# Occasion — environment variable template
# Copy to `.env` and fill in real values. Never commit `.env`.
# ---------------------------------------------------------------------------

# --- General ---------------------------------------------------------------
NODE_ENV=development

# --- Web app (apps/web) ----------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_AGENT_URL=http://localhost:8000

# --- Agent service (services/agent) ----------------------------------------
AGENT_PORT=8000
ANTHROPIC_API_KEY=

# --- Database --------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/occasion

# --- H Company (computer use) ----------------------------------------------
H_API_KEY=
H_API_BASE_URL=

# --- Gradium (voice: speech-to-text / text-to-speech) ----------------------
GRADIUM_API_KEY=

# --- Google (Gmail + Calendar) ---------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# --- Event distribution channels -------------------------------------------
LUMA_API_KEY=
PARTIFUL_API_KEY=
EVENTBRITE_API_TOKEN=
MEETUP_API_KEY=

# --- Payments --------------------------------------------------------------
STRIPE_SECRET_KEY=

# --- NemoClaw (browser runtime) --------------------------------------------
NEMOCLAW_CONFIG=infra/nemoclaw/config.yaml
